NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Reserved for future Claude integration
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Protect publish route and n8n calls
CONTENT_FACTORY_API_KEY=replace-with-a-long-random-secret

# Git commit identity used by /api/publish-article
GIT_AUTHOR_NAME=AI Content Factory
GIT_AUTHOR_EMAIL=content-factory@example.com
GIT_COMMITTER_NAME=AI Content Factory
GIT_COMMITTER_EMAIL=content-factory@example.com

# Optional status display
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://your-domain.com

# Social and LINE webhook placeholders for n8n
LINE_OA_PUSH_ENDPOINT=
LINE_OA_CHANNEL_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_WEBHOOK_URL=
THREADS_ACCESS_TOKEN=
THREADS_WEBHOOK_URL=
